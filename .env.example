# Copy to .env and fill in (backend/.env is gitignored). Do NOT commit real secrets.
#
# Settings profile (pick one)
DJANGO_SETTINGS_MODULE="config.settings.production"
# DJANGO_SETTINGS_MODULE=config.settings.production

# -----------------------------------------------------------------------------
# Core security / hosts
# -----------------------------------------------------------------------------
DEBUG="False"
# Django admin site path segment (no leading slash). Default: admin/
ADMIN_PATH="admin/"
# 32+ chars recommended (example only)
SECRET_KEY="change-me-to-a-long-random-secret-key"

# Backend hostnames (Django Host header validation)
ALLOWED_HOSTS="paperbase.me,www.paperbase.me,api.paperbase.me"

# Platform hosts (requests that should be treated as platform, not tenant host)
# Include localhost/127.0.0.1 for local runs.
PLATFORM_HOSTS="api.paperbase.me"

# Root domain used when generating store subdomains
PLATFORM_ROOT_DOMAIN="paperbase.me"

# Frontend base URL used for links in transactional emails (verification/reset)
FRONTEND_URL="https://dash.paperbase.me"

# -----------------------------------------------------------------------------
# Database (production uses Postgres)
# -----------------------------------------------------------------------------
# Railway Postgres (from DATABASE_URL / connection string: db name is path, user before @, host:port in middle)
DATABASE_URL=""

# -----------------------------------------------------------------------------
# Redis / Channels / Cache / Celery
# -----------------------------------------------------------------------------
# Single Railway-provided URL (Channels, Django cache, Celery broker).
REDIS_URL="redis://default:xtJZyNujSysIiXvqUVUcZBtrMvGVXcIO@redis.railway.internal:6379"

# Tenant resolution tuning (optional)
DOMAIN_RESOLUTION_CACHE_TTL="420"
TENANT_RESOLUTION_RATE_LIMIT_IP="120"
TENANT_RESOLUTION_RATE_LIMIT_DOMAIN="60"

# If behind a proxy/ingress that terminates TLS
USE_X_FORWARDED_PROTO="true"

# -----------------------------------------------------------------------------
# CORS / CSRF (set explicitly in production)
# -----------------------------------------------------------------------------
# Production enables CORS_ALLOW_ALL_ORIGINS (see config/settings/production.py);
# CORS_ALLOWED_ORIGINS is not read. CSRF still requires trusted origins below.
CSRF_TRUSTED_ORIGINS="https://paperbase.me,https://www.paperbase.me,https://dash.paperbase.me,https://www.dash.paperbase.me"

# -----------------------------------------------------------------------------
# Cloudflare R2 (production storage)
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID="b26a8e42f357f57b1374ebc34e819284"
R2_SECRET_ACCESS_KEY="22ce99c4bf9117ab99ac1b852d9efad3ef8a88e138c8fca8f8b37729d1adc47a"
R2_BUCKET_NAME="storage-paperbase"
R2_ENDPOINT_URL="https://0af0fd3cdbba495097b81f21ef1b3be7.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://cdn.paperbase.me"

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_crJxTn9S_BiNhmyJwUiqAXJqHhdF975Jk"

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (login / register)
# -----------------------------------------------------------------------------
# Leave empty to skip verification (typical local dev). Set in production.
TURNSTILE_SECRET_KEY=""
# If you keep a secret locally but want to bypass verification: "true" (never in production).
TURNSTILE_SKIP_VERIFICATION="false"

# Field encryption (if used)
FIELD_ENCRYPTION_KEY="change-me"